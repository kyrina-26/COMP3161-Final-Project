# =========================
# MySQL Container Initialization
# =========================
# Docker uses these to build the database when it first boots up.
MYSQL_ROOT_PASSWORD=your_local_password
MYSQL_DATABASE=course_management 
#This is the name of the database that will be created when the MySQL container starts. 
#You can change this if you want, but make sure to update DB_NAME below as well.

# =========================
# Flask Database Connection
# =========================
# app.py uses these to log into the database created above.
# DB_PASS and DB_NAME should match the MYSQL_ values above.
DB_HOST=db
DB_USER=root
DB_PASS=your_local_password
DB_NAME=course_management

# =========================
# Flask & API Settings
# =========================
FLASK_APP=app.py
FLASK_DEBUG=1

# =========================
# Authentication (JWT)
# =========================
# This key is used to sign your tokens. In your actual .env, make this a long, random string.
JWT_SECRET_KEY=your_super_secret_jwt_key_here
DEFAULT_PASSWORD=your_default_user_password_here
